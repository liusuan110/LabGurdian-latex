    set align(center)
    set text(size: 10.5pt, font: 宋体)
    [第 #counter(page).display() 页 共 #counter(page).final().at(0) 页]
  },
)

// 正文默认: 五号宋体 (10.5pt), 首行缩进 2 字符, 单倍行距
